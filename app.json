{
  "expo": {
    "name": "Dutch Smart Memory",
    "slug": "dutch-smart-memory",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B35"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dutchsmartmemory.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#FF6B35"
      },
      "package": "com.dutchsmartmemory.app"
    },
    "web": {
      "favicon": "./src/assets/favicon.png",
      "bundler": "metro",
      "baseUrl": "/dutch-smart-memory"
    }
  }
}
